<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="Infinity" maxWidth="Infinity" minHeight="Infinity"
            minWidth="Infinity" prefHeight="300.0" prefWidth="400.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.kafpin.lb3.NewStudentController">
    <children>
        <VBox spacing="5.0" AnchorPane.bottomAnchor="10.0"
              AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0"
              AnchorPane.topAnchor="10.0">
            <children>
                <Label text="Фамилия"/>
                <TextField fx:id="surnameField"/>
                <Label text="Имя"/>
                <TextField fx:id="nameField"/>
                <Label text="Отчество"/>
                <TextField fx:id="thirdnameField"/>
                <Label text="Возраст"/>
                <TextField fx:id="ageField"/>
                <Label text="Группа"/>
                <TextField fx:id="groupField"/>
                <Label text="Город"/>
                <TextField fx:id="cityField"/>
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button text="OK" onAction="#ok_click"/>
                        <Button text="Отмена" onAction="#cancel_click"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>